# LLM
OPENROUTER_API_KEY=your_openrouter_key_here

# Email delivery (Resend)
RESEND_API_KEY=your_resend_key_here
FROM_EMAIL=MindOS <learn@yourdomain.com>

# Google Sheets monitoring (optional but recommended)
GOOGLE_SHEET_ID=your_sheet_id_here
GOOGLE_CREDS_JSON={"type":"service_account","project_id":"..."}  # paste full JSON as one line

# App
DATABASE_PATH=mindos.db
BASE_URL=https://your-app.fly.dev
CRON_SECRET=a_random_secret_string
